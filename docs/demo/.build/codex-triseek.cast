[0.310, "o", "\u001bc\u001b[38;5;42m\u001b[1mCodex + TriSeek MCP\u001b[0m\r\n\u001b[2mSource: bench/results/rerun-2026-04-02-all\u001b[0m\r\n\u001b[2mRepo: torvalds/linux\u001b[0m\r\n\r\n\u001b[38;5;39m\u001b[1mScene 1/2: single lookup\u001b[0m\r\n\r\n\u001b[38;5;221mPrompt\u001b[0m\r\n"]
